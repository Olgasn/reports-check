@namespace ReportsCheck.Web.Components.Shared.Dialogs

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_surname" Label="Фамилия" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_name" Label="Имя" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_middlename" Label="Отчество" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string Surname { get; set; } = string.Empty;
    [Parameter] public string Middlename { get; set; } = string.Empty;

    private string _name = string.Empty;
    private string _surname = string.Empty;
    private string _middlename = string.Empty;

    protected override void OnInitialized()
    {
        _name = Name;
        _surname = Surname;
        _middlename = Middlename;
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok((_name, _surname, _middlename)));
    private void Cancel() => MudDialog.Cancel();
}
